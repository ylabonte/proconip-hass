#!/usr/bin/env bash

# Launch the mock ProCon.IP controller (aiohttp-based, drifting sensors +
# mutable relay/DMX state). Intended for dev use inside the devcontainer
# so you can exercise the Home Assistant integration end-to-end without
# owning real hardware.
#
# Default config: 127.0.0.1:8080, basic auth admin/admin. Override via
# env vars:
#
#   MOCK_HOST=0.0.0.0 MOCK_PORT=9999 MOCK_USER=foo MOCK_PASS=bar scripts/mock-server
#
# Add an integration entry in Home Assistant pointing at
# http://127.0.0.1:8080 with admin/admin to talk to this mock.

set -e

cd "$(dirname "$0")/.."

PYTHON=".venv/bin/python"

# When the devcontainer task runs this on folderOpen, postCreateCommand
# (scripts/setup) may still be installing into .venv. Wait up to ~3
# minutes for aiohttp to appear before exec'ing — otherwise we'd crash
# with ModuleNotFoundError.
WAIT_SECONDS=180
WAITED=0
while ! [ -x "$PYTHON" ] || ! "$PYTHON" -c "import aiohttp" >/dev/null 2>&1; do
    if [ "$WAITED" -ge "$WAIT_SECONDS" ]; then
        echo "Error: .venv still doesn't have aiohttp after ${WAIT_SECONDS}s." >&2
        echo "Run 'scripts/setup' manually to diagnose." >&2
        exit 1
    fi
    if [ "$WAITED" -eq 0 ]; then
        echo "Waiting for .venv to be ready (scripts/setup still running?)..."
    fi
    sleep 2
    WAITED=$((WAITED + 2))
done

exec "$PYTHON" -m tools.proconip_mock \
    --host "${MOCK_HOST:-127.0.0.1}" \
    --port "${MOCK_PORT:-8080}" \
    --username "${MOCK_USER:-admin}" \
    --password "${MOCK_PASS:-admin}"
