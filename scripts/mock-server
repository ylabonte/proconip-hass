#!/usr/bin/env bash

# Foreground mock ProCon.IP controller. Logs to stdout. Use this for
# manual smoke-testing from a terminal; for headless devcontainer
# auto-start see .devcontainer/start-mock.sh (wired into postStartCommand).
#
# Configuration is via environment variables, matching the mock package:
#
#   PROCONIP_MOCK_HOST=0.0.0.0   # default 127.0.0.1 (loopback only)
#   PROCONIP_MOCK_PORT=8080
#   PROCONIP_MOCK_USER=admin
#   PROCONIP_MOCK_PASS=admin
#
# Defaults bind to loopback so the default admin/admin creds aren't
# exposed to the LAN. Override to 0.0.0.0 only when you need host-side
# port forwarding or other-container access.

set -e

cd "$(dirname "$0")/.."

PYTHON=".venv/bin/python"

# When the devcontainer's postStartCommand fires this on container
# start, postCreateCommand (scripts/setup) may still be installing into
# .venv. Wait up to ~3 minutes for aiohttp to appear before exec'ing —
# otherwise we'd crash with ModuleNotFoundError.
WAIT_SECONDS=180
WAITED=0
while ! [ -x "$PYTHON" ] || ! "$PYTHON" -c "import aiohttp" >/dev/null 2>&1; do
    if [ "$WAITED" -ge "$WAIT_SECONDS" ]; then
        echo "Error: .venv still doesn't have aiohttp after ${WAIT_SECONDS}s." >&2
        echo "Run 'scripts/setup' manually to diagnose." >&2
        exit 1
    fi
    if [ "$WAITED" -eq 0 ]; then
        echo "Waiting for .venv to be ready (scripts/setup still running?)..."
    fi
    sleep 2
    WAITED=$((WAITED + 2))
done

exec "$PYTHON" -m tools.proconip_mock
