#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Pick the newest Python >= 3.14.2 we can find. 3.14 is our *dev/CI* floor
# (not the runtime floor — shipped users only need 3.13). The reason it's
# 3.14.2 here: this script installs the [dev,test] extras, which pull in
# pytest-homeassistant-custom-component → current HA Core (2026.5+) → which
# itself requires Python >= 3.14.2. Override with
# `PYTHON=python3.X scripts/setup` if you know what you are doing.
# Reusable predicate: 0 iff the given interpreter is >= 3.14.2.
# HA Core 2026.5.x needs that exact micro; on 3.14.0/3.14.1 the
# [dev,test] install would otherwise fail at pip-resolve time with a
# confusing error rather than here.
python_is_supported() {
    "$1" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 14, 2) else 1)' 2>/dev/null
}

if [ -n "${PYTHON:-}" ]; then
    # Respect the override, but apply the same gate to it so a user-
    # supplied bad interpreter (PYTHON=python3.13, or a 3.14.0/3.14.1)
    # is rejected up front rather than silently re-used.
    if ! command -v "$PYTHON" >/dev/null 2>&1; then
        echo "Error: PYTHON override '$PYTHON' not found in PATH" >&2
        exit 1
    fi
    if ! python_is_supported "$PYTHON"; then
        actual_ver="$("$PYTHON" -c 'import sys; print(sys.version.split()[0])' 2>/dev/null || echo unknown)"
        echo "Error: PYTHON override '$PYTHON' is $actual_ver; setup requires >= 3.14.2" >&2
        exit 1
    fi
else
    for candidate in python3.14 python3; do
        if command -v "$candidate" >/dev/null 2>&1 && python_is_supported "$candidate"; then
            PYTHON="$candidate"
            break
        fi
    done
fi

if [ -z "${PYTHON:-}" ]; then
    echo "Error: no Python >= 3.14.2 found in PATH" >&2
    exit 1
fi

echo "==> Using $PYTHON ($("$PYTHON" --version))"

# Create or repair the venv.
# We use `python -m venv .venv --clear` rather than `rm -rf .venv` so this
# also works when .venv is a mounted volume (as in our devcontainer), which
# can't be removed with rm because the mount point itself is busy. `--clear`
# wipes only the contents and recreates the venv structure inside.
#
# Rebuild when ANY of: no usable interpreter, broken interpreter,
# interpreter below the >=3.14.2 floor, or interpreter major.minor does
# not match the just-selected $PYTHON. The micro check matters because
# an existing .venv built with 3.14.0/3.14.1 looks fine on a major.minor
# comparison against `python3.14`, but [dev,test] dep resolution against
# current HA Core will fail later with a confusing pip error.
NEEDS_REBUILD=
if [ ! -x .venv/bin/python ] || ! .venv/bin/python --version >/dev/null 2>&1; then
    NEEDS_REBUILD=1
    REBUILD_REASON="missing/broken interpreter"
elif ! python_is_supported .venv/bin/python; then
    VENV_FULL="$(.venv/bin/python -c 'import sys; print(sys.version.split()[0])' 2>/dev/null || echo unknown)"
    NEEDS_REBUILD=1
    REBUILD_REASON="existing .venv uses Python $VENV_FULL, setup requires >= 3.14.2"
else
    VENV_VER="$(.venv/bin/python -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
    PY_VER="$("$PYTHON" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
    if [ "$VENV_VER" != "$PY_VER" ]; then
        NEEDS_REBUILD=1
        REBUILD_REASON="existing .venv uses Python $VENV_VER, selected $PYTHON is $PY_VER"
    fi
fi

if [ -n "$NEEDS_REBUILD" ]; then
    if [ -d .venv ] && [ -n "$(ls -A .venv 2>/dev/null)" ]; then
        echo "==> Recreating .venv ($REBUILD_REASON)"
    else
        echo "==> Creating .venv"
    fi
    "$PYTHON" -m venv .venv --clear
fi

.venv/bin/python -m pip install --upgrade pip setuptools

# Project + dev + test deps. pytest-homeassistant-custom-component pulls
# in `homeassistant` itself, so we don't need to list it explicitly.
.venv/bin/python -m pip install --upgrade -e ".[dev,test]"

# colorlog gives the `hass` CLI nice colored output.
.venv/bin/python -m pip install --upgrade colorlog

# Pre-install HA's eager-import + slim-config integration requirements
# by walking HA's own manifest.json files. Avoids the lazy-install race
# on first `scripts/develop` (where HA's async installer loses to
# component imports and lands us in recovery mode). See the script's
# docstring for the full why.
.venv/bin/python scripts/install-ha-deps.py
