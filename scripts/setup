#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Pick the newest Python >= 3.13 we can find (3.13 is our floor; later
# minors are fine). Override with `PYTHON=python3.X scripts/setup`.
if [ -z "${PYTHON:-}" ]; then
    for candidate in python3.14 python3.13 python3; do
        if command -v "$candidate" >/dev/null 2>&1; then
            ver="$("$candidate" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
            case "$ver" in
                3.13|3.14|3.15|3.16)
                    PYTHON="$candidate"
                    break
                    ;;
            esac
        fi
    done
fi

if [ -z "${PYTHON:-}" ]; then
    echo "Error: no Python >= 3.13 found in PATH" >&2
    exit 1
fi

echo "==> Using $PYTHON ($("$PYTHON" --version))"

# Create or repair the venv.
# We use `python -m venv .venv --clear` rather than `rm -rf .venv` so this
# also works when .venv is a mounted volume (as in our devcontainer), which
# can't be removed with rm because the mount point itself is busy. `--clear`
# wipes only the contents and recreates the venv structure inside.
if [ ! -x .venv/bin/python ] || ! .venv/bin/python --version >/dev/null 2>&1; then
    if [ -d .venv ] && [ -n "$(ls -A .venv 2>/dev/null)" ]; then
        echo "==> Existing .venv is empty or broken; clearing and recreating"
    else
        echo "==> Creating .venv"
    fi
    "$PYTHON" -m venv .venv --clear
fi

.venv/bin/python -m pip install --upgrade pip setuptools
.venv/bin/python -m pip install --upgrade -e ".[dev,test]"

# Pre-install home-assistant-frontend so the dev HA instance doesn't have to
# race lazy-install vs first-import on startup (it loses, frontend ends up
# in recovery mode). This package is ~50 MB and HA Core does NOT install it
# automatically — it's a runtime-only lazy dep.
.venv/bin/python -m pip install --upgrade home-assistant-frontend

# Pre-install deps for HA's hardcoded "base components" list. HA's
# helpers/service.py:_base_components() imports ai_task / camera /
# conversation / ffmpeg / tts / etc. *unconditionally* — --skip-pip on the
# HA process doesn't help because the imports happen at module-load time,
# not via the pip-install-on-demand path. The frontend's `get_services`
# call fires _base_components() and crashes on the first missing dep,
# which blocks every UI render. Pre-installing covers the chain.
.venv/bin/python -m pip install --upgrade \
    hassil \
    home-assistant-intents \
    ha-ffmpeg \
    PyTurboJPEG \
    'rf-protocols==2.2.0' \
    'infrared-protocols==2.0.0' \
    mutagen \
    av \
    PyMetno \
    radios \
    pycountry \
    aiodhcpwatcher \
    aiousbwatcher \
    aiodiscover \
    cached-ipaddress \
    async-upnp-client \
    file-read-backwards \
    serialx
