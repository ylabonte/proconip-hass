#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Pick the newest Python >= 3.13 we can find (3.13 is our floor; later
# minors are fine). Override with `PYTHON=python3.X scripts/setup`.
if [ -z "${PYTHON:-}" ]; then
    for candidate in python3.14 python3.13 python3; do
        if command -v "$candidate" >/dev/null 2>&1; then
            ver="$("$candidate" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
            case "$ver" in
                3.13|3.14|3.15|3.16)
                    PYTHON="$candidate"
                    break
                    ;;
            esac
        fi
    done
fi

if [ -z "${PYTHON:-}" ]; then
    echo "Error: no Python >= 3.13 found in PATH" >&2
    exit 1
fi

echo "==> Using $PYTHON ($("$PYTHON" --version))"

# If .venv exists but its python is broken (e.g., a host venv mounted into a
# container where the symlinked Python doesn't exist), recreate it.
if [ -d .venv ] && ! .venv/bin/python --version >/dev/null 2>&1; then
    echo "==> Existing .venv has a non-working Python interpreter; recreating"
    rm -rf .venv
fi

if [ ! -x .venv/bin/python ]; then
    echo "==> Creating .venv"
    "$PYTHON" -m venv .venv
fi

.venv/bin/python -m pip install --upgrade pip setuptools
.venv/bin/python -m pip install --upgrade -e ".[dev,test]"
