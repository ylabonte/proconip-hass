#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Pick the newest Python >= 3.14 we can find. 3.14 is our *dev/CI* floor
# (not the runtime floor — shipped users only need 3.13). The reason it's
# 3.14 here: this script installs the [dev,test] extras, which pull in
# pytest-homeassistant-custom-component → current HA Core (2026.5+) → which
# itself requires Python >= 3.14.2. Override with
# `PYTHON=python3.X scripts/setup` if you know what you are doing.
if [ -z "${PYTHON:-}" ]; then
    for candidate in python3.14 python3; do
        if command -v "$candidate" >/dev/null 2>&1; then
            ver="$("$candidate" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
            case "$ver" in
                3.14|3.15|3.16)
                    PYTHON="$candidate"
                    break
                    ;;
            esac
        fi
    done
fi

if [ -z "${PYTHON:-}" ]; then
    echo "Error: no Python >= 3.14 found in PATH" >&2
    exit 1
fi

echo "==> Using $PYTHON ($("$PYTHON" --version))"

# Create or repair the venv.
# We use `python -m venv .venv --clear` rather than `rm -rf .venv` so this
# also works when .venv is a mounted volume (as in our devcontainer), which
# can't be removed with rm because the mount point itself is busy. `--clear`
# wipes only the contents and recreates the venv structure inside.
if [ ! -x .venv/bin/python ] || ! .venv/bin/python --version >/dev/null 2>&1; then
    if [ -d .venv ] && [ -n "$(ls -A .venv 2>/dev/null)" ]; then
        echo "==> Existing .venv is empty or broken; clearing and recreating"
    else
        echo "==> Creating .venv"
    fi
    "$PYTHON" -m venv .venv --clear
fi

.venv/bin/python -m pip install --upgrade pip setuptools

# Project + dev + test deps. pytest-homeassistant-custom-component pulls
# in `homeassistant` itself, so we don't need to list it explicitly.
.venv/bin/python -m pip install --upgrade -e ".[dev,test]"

# colorlog gives the `hass` CLI nice colored output.
.venv/bin/python -m pip install --upgrade colorlog

# Pre-install HA's eager-import + slim-config integration requirements
# by walking HA's own manifest.json files. Avoids the lazy-install race
# on first `scripts/develop` (where HA's async installer loses to
# component imports and lands us in recovery mode). See the script's
# docstring for the full why.
.venv/bin/python scripts/install-ha-deps.py
