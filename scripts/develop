#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Use the venv's binaries explicitly so this works whether or not the
# user has activated .venv in their shell.
HASS=".venv/bin/hass"
if [ ! -x "$HASS" ]; then
    echo "Error: $HASS not found. Run scripts/setup first." >&2
    exit 1
fi

# Create config dir if not present
if [ ! -d "${PWD}/config" ]; then
    mkdir -p "${PWD}/config"
    "$HASS" --config "${PWD}/config" --script ensure_config
fi

# Set the path to custom_components
## This let's us have the structure we want <root>/custom_components/proconip
## while at the same time have Home Assistant configuration inside <root>/config
## without resulting to symlinks.
export PYTHONPATH="${PYTHONPATH}:${PWD}/custom_components"

# Start Home Assistant. We deliberately do NOT pass --skip-pip:
# HA's helpers/service.py:_base_components() unconditionally imports
# ~19 built-in components at module-load time, each with its own
# transitive Python deps (mutagen, pymicro_vad, …). Keeping --skip-pip
# would leave gaps in that import chain and crash every get_services
# WebSocket call (the frontend can't render without it). Letting HA
# lazy-install the missing pieces on first boot is slower once but
# produces a working UI. Subsequent boots are fast because the deps
# are cached.
"$HASS" --config "${PWD}/config" --debug
