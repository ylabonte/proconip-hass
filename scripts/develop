#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Use the venv's binaries explicitly so this works whether or not the
# user has activated .venv in their shell.
HASS=".venv/bin/hass"
if [ ! -x "$HASS" ]; then
    echo "Error: $HASS not found. Run scripts/setup first." >&2
    exit 1
fi

# Create config dir if not present
if [ ! -d "${PWD}/config" ]; then
    mkdir -p "${PWD}/config"
    "$HASS" --config "${PWD}/config" --script ensure_config
fi

# Set the path to custom_components
## This let's us have the structure we want <root>/custom_components/proconip
## while at the same time have Home Assistant configuration inside <root>/config
## without resulting to symlinks.
export PYTHONPATH="${PYTHONPATH}:${PWD}/custom_components"

# Start Home Assistant. --skip-pip stops HA from trying to lazy-install
# missing component dependencies (ffmpeg, conversation, camera, …) at
# runtime, which would otherwise produce file-system churn that trips
# Pylance/mypy LSPs into "Server[N] disconnected unexpectedly" popups.
# Components whose deps aren't installed fail fast and cleanly.
"$HASS" --config "${PWD}/config" --debug --skip-pip
