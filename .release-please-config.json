{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "tag-separator": "",
  "changelog-path": "CHANGELOG.md",
  "packages": {
    ".": {
      "package-name": "proconip-hass",
      "extra-files": [
        {
          "type": "json",
          "path": "custom_components/proconip_pool_controller/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "generic",
          "path": "custom_components/proconip_pool_controller/const.py"
        }
      ],
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance" },
        { "type": "revert", "section": "Reverts" },
        { "type": "deps", "section": "Dependencies" },
        { "type": "docs", "section": "Documentation", "hidden": false },
        { "type": "refactor", "section": "Refactor", "hidden": true },
        { "type": "test", "section": "Tests", "hidden": true },
        { "type": "build", "section": "Build System", "hidden": true },
        { "type": "ci", "section": "CI / Tooling", "hidden": true },
        { "type": "chore", "section": "Miscellaneous", "hidden": true }
      ]
    }
  }
}
